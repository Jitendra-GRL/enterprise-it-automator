{
  "uid": "it-automator-overview",
  "title": "IT Automator — Overview",
  "tags": ["it-automator"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "timeseries", "title": "HTTP request rate by route",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum by (path) (rate(http_requests_total[5m]))",
        "legendFormat": "{{path}}"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 2, "type": "timeseries", "title": "HTTP 5xx error ratio",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total[5m])), 1e-10)",
        "legendFormat": "5xx ratio"
      }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "min": 0 }, "overrides": [] }
    },
    {
      "id": 3, "type": "timeseries", "title": "Request latency p50 / p95 (POST /tickets)",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum by (le) (rate(http_request_duration_seconds_bucket{path=\"/tickets\"}[5m])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{path=\"/tickets\"}[5m])))", "legendFormat": "p95" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 4, "type": "timeseries", "title": "Tickets finalized by status",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum by (status) (increase(tickets_finalized_total[1h]))",
        "legendFormat": "{{status}}"
      }],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 5, "type": "stat", "title": "Approvals pending",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "approvals_pending", "legendFormat": "pending" }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 10 } ] } }, "overrides": [] }
    },
    {
      "id": 6, "type": "stat", "title": "Escalations (24h)",
      "gridPos": { "x": 6, "y": 16, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "increase(approvals_escalated_total[24h])", "legendFormat": "escalated" }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } }, "overrides": [] }
    },
    {
      "id": 7, "type": "timeseries", "title": "LLM tokens by direction (rate)",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum by (direction) (rate(llm_tokens_total[15m])) * 60",
        "legendFormat": "{{direction}} /min"
      }],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 8, "type": "timeseries", "title": "MCP tool calls by outcome",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum by (outcome) (rate(mcp_tool_calls_total[5m]))",
        "legendFormat": "{{outcome}}"
      }],
      "fieldConfig": { "defaults": { "unit": "cps" }, "overrides": [] }
    },
    {
      "id": 9, "type": "state-timeline", "title": "Circuit breakers (1 = open/half-open)",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "max by (domain) (mcp_circuit_breaker_open)",
        "legendFormat": "{{domain}}"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "max": 1, "min": 0 }, "overrides": [] }
    }
  ]
}
