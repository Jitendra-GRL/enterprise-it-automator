# LLM backend: "groq" (free/fast, default), "anthropic", or "watsonx"
LLM_PROVIDER=groq

# Groq (https://console.groq.com/keys) — free tier
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Anthropic (optional alternate backend)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# IBM watsonx.ai (optional alternate backend)
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL=ibm/granite-3-8b-instruct

# Database — defaults to local SQLite file, no setup required.
# For Postgres: postgresql+asyncpg://user:password@localhost:5432/it_automator
DATABASE_URL=sqlite+aiosqlite:///./it_automator.db

# Actions requiring human-in-the-loop approval before the MCP server executes them
SENSITIVE_ACTIONS=disable_user,revoke_access

# API server
API_HOST=0.0.0.0
API_PORT=8000
